# --- Local dev (`.env`) ---
# Use same-origin `/api`; Vite proxies to `VITE_PROXY_TARGET` (see vite.config.ts).
VITE_API_BASE_URL=/api
# Or: VITE_API_URL=/api

# --- Production build ---
# `vite build` loads `.env.production` (committed) with:
#   VITE_API_URL=https://nectar-xirj.onrender.com
# Override there only if the API origin changes.

# Optional: Google Apps Script web app URL. If unset, checkout uses the Node checkout route.
# VITE_GOOGLE_APPS_SCRIPT_ORDER_URL=https://script.google.com/macros/s/.../exec

# In dev, proxy /api and /orders to this backend.
# Examples:
#   VITE_PROXY_TARGET=https://nectar-xirj.onrender.com
#   VITE_PROXY_TARGET=http://localhost:3000
#   VITE_PROXY_TARGET=http://127.0.0.1:3000
