# Relative API prefix in dev: Vite proxies `/api` → backend (default http://localhost:3000).
# Production: set to `/api` if hosting rewrites, or an absolute API origin.
VITE_API_URL=/api

# Alternative: absolute API origin for production builds (overridden when VITE_API_URL is set).
# VITE_API_BASE_URL=https://api.perfumenectar.com

# Used when VITE_GOOGLE_APPS_SCRIPT_ORDER_URL is not set (checkout posts to `${VITE_API_URL}/orders/checkout`).
# Default in code is same-origin `/api` (Vite dev proxies to VITE_PROXY_TARGET).

# Optional: Google Apps Script web app URL. If unset, checkout uses the Node checkout route.
# VITE_GOOGLE_APPS_SCRIPT_ORDER_URL=https://script.google.com/macros/s/.../exec

# In dev, proxy /api requests to this backend.
# Examples:
#   VITE_PROXY_TARGET=http://localhost:3000
#   VITE_PROXY_TARGET=http://127.0.0.1:3000
# VITE_PROXY_TARGET=http://localhost:3000
