# API base URL – no local fallback; used for checkout and all API calls.
# Set to production API for both dev and production builds.
VITE_API_BASE_URL=https://api.perfumenectar.com

# In dev, proxy /api requests to this backend (so API calls hit your server).
# Use your server IP or hostname and port (e.g. where you run the Node server).
# Examples:
#   VITE_PROXY_TARGET=http://localhost:3000
#   VITE_PROXY_TARGET=http://ip-172-31-12-231:3000
#   VITE_PROXY_TARGET=http://YOUR_SERVER_PUBLIC_IP:3000
# VITE_PROXY_TARGET=http://localhost:3000
