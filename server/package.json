{
  "name": "nectar-api",
  "version": "2.0.0",
  "type": "module",
  "description": "Backend API for Nectar perfume shop",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "pm2 start ecosystem.config.js --env production",
    "start:dev": "pm2 start ecosystem.config.js --env development",
    "dev": "node --watch server.js",
    "docker:build": "docker build -t nectar-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env nectar-api",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "mongodb": "^6.3.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^7.0.12",
    "pg": "^8.18.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.0",
    "winston": "^3.11.0"
  },
  "keywords": [
    "api",
    "ecommerce",
    "perfume"
  ],
  "author": "",
  "license": "ISC"
}
