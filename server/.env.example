# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email Configuration (Gmail) - REQUIRED for order confirmation emails
# Use a Gmail APP PASSWORD (not your normal password). See EMAIL_SETUP.md for steps.
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
ORDER_EMAIL=your-email@gmail.com
SHOP_NAME=Nectar Perfume Shop

OWNER_PHONE=+96181353685

# Security – comma-separated; no * when using credentials. Production + local dev example:
# CORS_ORIGINS=https://perfumenectar.com,https://www.perfumenectar.com,http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
API_KEY=your-optional-api-key

# Logging
LOG_LEVEL=info

# Database Configuration
# Supported types: mongodb, postgresql, mysql
# Default: postgresql
DB_TYPE=mongodb

# MongoDB Configuration (if DB_TYPE=mongodb)
# Option 1: Use DB_URI for connection string (recommended)
DB_URI=mongodb://localhost:27017/nectar_db
# Option 2: Use individual connection parameters
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=nectar_db
# DB_USER=
# DB_PASSWORD=

# PostgreSQL Configuration (if DB_TYPE=postgresql)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nectar_db
# DB_USER=postgres
# DB_PASSWORD=your-password

# MySQL Configuration (if DB_TYPE=mysql)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=nectar_db
# DB_USER=root
# DB_PASSWORD=your-password

# Database Pool Configuration (optional)
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_POOL_CONNECTION_TIMEOUT=5000
# DB_STATEMENT_TIMEOUT=30000
